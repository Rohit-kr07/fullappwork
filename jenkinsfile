pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                echo 'Code Cloned'
            }
        }

        stage('Build Backend') {
            steps {
                dir('backend') {
                    sh 'npm install'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    sh 'npm install'
                }
            }
        }
    }
}